{
  "compilerOptions": {
    "lib": ["ES2020"],
    "types": ["node"],
    "allowJs": true,
    "outDir": "dist",
    "target": "ES2020",
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "checkJs": false,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "forceConsistentCasingInFileNames": false,
    "baseUrl": ".",
    "paths": {
      "@mavibase/api": ["packages/api/src/index.ts"],
      "@mavibase/api/*": ["packages/api/src/*"],
      "@mavibase/core": ["packages/core/src/index.ts"],
      "@mavibase/core/*": ["packages/core/src/*"],
      "@mavibase/database": ["packages/database/src/index.ts"],
      "@mavibase/database/*": ["packages/database/src/*"],
      "@mavibase/platform": ["packages/platform/src/index.ts"],
      "@mavibase/platform/*": ["packages/platform/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}

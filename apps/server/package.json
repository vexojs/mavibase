    "start": "node dist/main.js"
  },
  "dependencies": {
    "@mavibase/core": "file:../../packages/core",
    "@mavibase/database": "file:../../packages/database",
    "@mavibase/api": "file:../../packages/api",
    "@mavibase/platform": "file:../../packages/platform",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.5.1",
    "cookie-parser": "^1.4.7",
    "uuid": "^9.0.1",
    "argon2": "^0.44.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/cors": "^2.8.17",
    "@types/pg": "^8.10.9",
    "@types/node": "^20.10.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/uuid": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0"

# ============================================
# MAVIBASE CONFIGURATION GUIDE
# ============================================
# 
# IMPORTANT: Read docs/SELF_HOSTING.md for detailed setup instructions
#
# Two deployment modes:
#   1. DOCKER COMPOSE (Local/Self-hosted) - docker compose up -d
#   2. PRODUCTION/BYOD (External DBs)    - docker compose -f docker-compose.prod.yml up -d
#
# See the sections below for which variables to use in each mode.
# ============================================

# ============================================
# Server Configuration
# ============================================
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
EGRESS_LIMIT_PER_PROJECT=1 #in GB
SLOW_QUERY_THRESHOLD_MS=500
DB_STATEMENT_TIMEOUT=30000
# ============================================
# DATABASE CONFIGURATION - CHOOSE ONE MODE:
# ============================================
#
# MODE 1: DOCKER COMPOSE (Local/Self-hosted)
# -----------------------------------------
# Use this for "docker compose up -d"
# Only set the PASSWORD - docker-compose.yml builds the URLs automatically
#
#   DB_PASSWORD=your-secure-postgres-password-here
#   REDIS_PASSWORD=your-secure-redis-password-here
#
# Do NOT set DATABASE_URL, PLATFORM_DB_URL, REDIS_URL in this mode!
#
# MODE 2: PRODUCTION / BYOD (External Databases)
# -----------------------------------------------
# Use this for "docker compose -f docker-compose.prod.yml up -d"
# Set FULL connection URLs to external services (Neon, Supabase, Upstash, AWS RDS, etc.)
#
#   DATABASE_URL=postgresql://user:password@your-host.neon.tech:5432/mavibase_db?sslmode=require
#   PLATFORM_DB_URL=postgresql://user:password@your-host.neon.tech:5432/mavibase_platform?sslmode=require
#   REDIS_URL=redis://:password@your-redis-host.upstash.io:6379
#
# ============================================

# ---- For Docker Compose Mode ----
# Uncomment these and set your passwords only:
DB_PASSWORD=your-secure-postgres-password-here
REDIS_PASSWORD=your-secure-redis-password-here

# ---- For Production / BYOD Mode ----
# Comment out DB_PASSWORD/REDIS_PASSWORD above and uncomment these with your real URLs:
# DATABASE_URL=postgresql://user:password@host:5432/mavibase_db?sslmode=require
# PLATFORM_DB_URL=postgresql://user:password@host:5432/mavibase_platform?sslmode=require
# REDIS_URL=redis://:password@host:6379

# ============================================
# CORS & Frontend Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# CORS Preflight Caching (in seconds)
# Browsers cache OPTIONS responses for this duration (default: 24 hours)
# Reduces server load from preflight requests
CORS_MAX_AGE=86400
# For production, update to your domain:
# ALLOWED_ORIGINS=https://console.yourdomain.com,https://yourdomain.com
# CORS_ORIGIN=https://console.yourdomain.com
# FRONTEND_URL=https://console.yourdomain.com

# ============================================
# Document Settings
# ============================================
MAX_REQUEST_BODY_SIZE=1mb
MAX_DOCUMENT_SIZE_KB=256
MAX_QUERY_LIMIT=100
MAX_BULK_OPERATIONS=1000

# ============================================
# Schema Validation
# ============================================
REJECT_UNKNOWN_FIELDS=false
ENABLE_SCHEMA_VALIDATION=true

# ============================================
# Document Versioning
# ============================================
ENABLE_VERSIONING=true
VERSION_LIMIT=10

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# ============================================
# Database Quotas (per project)
# ============================================
DEFAULT_MAX_COLLECTIONS=50
DEFAULT_MAX_DOCUMENTS_PER_COLLECTION=100000
DEFAULT_MAX_STORAGE_MB=1000

# ============================================
# JWT & Token Configuration
# IMPORTANT: Change these in production!
# Generate with: openssl rand -base64 32
# ============================================
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

JWT_EXPIRES_IN=15m
JWT_ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# API Key Security
# IMPORTANT: Change this in production!
# Minimum 32 characters, random string
# ============================================
API_KEY_PEPPER=your-extremely-strong-random-pepper-min-32-chars-change-in-production

# ============================================
# Internal API Security
# IMPORTANT: Change this in production!
# ============================================
INTERNAL_API_KEY=your-internal-api-key-min-32-chars-change-in-production
IDENTITY_CACHE_TTL_SECONDS=300

# ============================================
# Email Configuration (Optional)
# ============================================
# Set to true to enable email verification
# If false, users are auto-verified on signup
ENABLE_EMAIL_SERVICE=false
NEXT_PUBLIC_ENABLE_EMAIL_SERVICE=false

# SMTP Settings (only needed if ENABLE_EMAIL_SERVICE=true)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Mavibase

EMAIL_VERIFICATION_URL=http://localhost:3000/account/verify-email
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# 2FA Configuration
# ============================================
TWO_FA_CODE_EXPIRY_MINUTES=10
TWO_FA_CODE_LENGTH=6

# ============================================
# Session Configuration
# ============================================
SESSION_EXPIRY_HOURS=24
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=2

# ============================================
# Security Headers & HTTPS Enforcement
# ============================================
# Enable/disable security headers globally
ENABLE_SECURITY_HEADERS=true

# HTTPS enforcement (auto-redirect HTTP to HTTPS)
# Only active in production (NODE_ENV=production)
ENFORCE_HTTPS=true

# HSTS (HTTP Strict Transport Security) Configuration
# max-age in seconds (31536000 = 1 year)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# Content Security Policy (optional override)
# CSP_DIRECTIVES="default-src 'none'; frame-ancestors 'none'"

# Content-Type Validation
# Enforces Content-Type header on POST/PUT/PATCH/DELETE requests
CONTENT_TYPE_VALIDATION=true
# Comma-separated list of allowed content types (default: application/json)
# ALLOWED_CONTENT_TYPES=application/json
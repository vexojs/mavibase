# ============================================
# Multi-Tenant BaaS System Configuration
# ============================================

# Server Configuration
# Both platform and database services run on this single port
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
# ============================================
# Database Configuration (PostgreSQL)
# ============================================

# Database Product Service
DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database_name>

# Platform / Control Plane Database
PLATFORM_DB_URL=postgresql://<username>:<password>@<host>:<port>/<platform_database_name>

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=

# ============================================
# Document Settings
# ============================================
MAX_REQUEST_BODY_SIZE=1mb
MAX_DOCUMENT_SIZE_KB=256
MAX_QUERY_LIMIT=100
MAX_BULK_OPERATIONS=1000

# ============================================
# Schema Validation
# ============================================
REJECT_UNKNOWN_FIELDS=false
ENABLE_SCHEMA_VALIDATION=true

# ============================================
# Schema Versioning
# ============================================
ENABLE_VERSIONING=true
VERSION_LIMIT=5

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10000

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ============================================
# Frontend URL
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Database Quotas (per project)
# ============================================
DEFAULT_MAX_COLLECTIONS=100
DEFAULT_MAX_DOCUMENTS_PER_COLLECTION=500
DEFAULT_MAX_STORAGE_MB=1024

# ============================================
# JWT & Token Configuration
# ============================================
ACCESS_TOKEN_SECRET=your-super-secret-access-token-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

JWT_EXPIRES_IN=15m
JWT_ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRY=7d

# ============================================
# API Key Security
# ============================================
API_KEY_PEPPER=your-extremely-strong-random-pepper-min-32-chars-change-in-production

# ============================================
# Email Configuration
# ============================================
# Backend: Controls whether email service is initialized and emails are sent
# If false, users are automatically verified on registration
ENABLE_EMAIL_SERVICE=false

# Frontend: Controls whether email verification banner is shown
# Should match ENABLE_EMAIL_SERVICE for consistent behavior
NEXT_PUBLIC_ENABLE_EMAIL_SERVICE=false

EMAIL_PROVIDER= #smtp

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

EMAIL_VERIFICATION_URL=http://localhost:3000/account/verify-email
EMAIL_FROM=

# ============================================
# 2FA Configuration
# ============================================
TWO_FA_CODE_EXPIRY_MINUTES=10
TWO_FA_CODE_LENGTH=6

# ============================================
# Session Configuration
# ============================================
SESSION_EXPIRY_HOURS=24
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MINUTES=2

# ============================================
# Security Headers & HSTS
# ============================================
ENABLE_SECURITY_HEADERS=true
HSTS_MAX_AGE=31536000

# ============================================
# Internal API Security
# ============================================
INTERNAL_API_KEY=your-internal-api-key-min-32-chars-change-in-production
IDENTITY_CACHE_TTL_SECONDS=300
